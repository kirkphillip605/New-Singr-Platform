---
import Layout from '../layouts/Layout.astro';
import { GlassCard, GlassButton } from '@singr/ui';

interface Tier {
  stripePriceId: string;
  name: string;
  priceCents: number;
  interval: string;
  features: string[] | any;
  active: boolean;
}

const hostPortalUrl = import.meta.env.PUBLIC_HOST_PORTAL_URL || "https://host.singrkaraoke.com";
const apiUrl = import.meta.env.PUBLIC_API_URL || "https://api.singrkaraoke.com";

const commonFeatures = [
  "Unlimited Rigs & Systems",
  "Unlimited Shows & Venues",
  "Unlimited Songs & Updates",
  "Direct OpenKJ Compatibility",
  "Universal Singr Receiver App",
  "Manual Song Request Bridge",
  "Venue Details powered by Google",
  "Delegated Team & DJ Access",
  "Premium Onboarding Support"
];

let tiers: Tier[] = [];
let errorMsg = "";

try {
  const res = await fetch(`${apiUrl}/api/v1/billing/tiers`, {
    signal: AbortSignal.timeout(2000)
  });
  if (res.ok) {
    const data = await res.json();
    tiers = data.tiers || [];
  } else {
    throw new Error(`Failed to load: ${res.statusText}`);
  }
} catch (err: any) {
  errorMsg = err.message || String(err);
  // Graceful fallback to Singr Connect premium static tiers matching local development seeds
  tiers = [
    {
      stripePriceId: "price_1TOBKUEHv8jD9HNKuH9i3sEy",
      name: "Singr Connect Monthly",
      priceCents: 1500,
      interval: "month",
      features: commonFeatures,
      active: true
    },
    {
      stripePriceId: "price_1TOBKVEHv8jD9HNKcXvrP2Po",
      name: "Singr Connect 6-Month",
      priceCents: 7500,
      interval: "6_months",
      features: commonFeatures,
      active: true
    },
    {
      stripePriceId: "price_1TOBKVEHv8jD9HNKK0nTrlRV",
      name: "Singr Connect Annual",
      priceCents: 13500,
      interval: "year",
      features: commonFeatures,
      active: true
    }
  ];
}

const formatPrice = (cents: number) => {
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    minimumFractionDigits: 0
  }).format(cents / 100);
};

const getIntervalText = (interval: string) => {
  if (interval === 'month') return 'month';
  if (interval === '6_months') return '6 months';
  if (interval === 'year') return 'year';
  return interval;
};

const getPlanName = (interval: string) => {
  if (interval === 'month') return 'monthly';
  if (interval === '6_months') return 'six_month';
  if (interval === 'year') return 'annual';
  return interval;
};
---

<Layout title="Simple Transparent Pricing — Singr Karaoke">
  <section class="py-12">
    <div class="max-w-3xl mx-auto text-center mb-16">
      <span class="text-xs font-bold uppercase tracking-widest text-[var(--singr-accent-primary)] mb-3 block font-sans">Flexible Subscription Models</span>
      <h1 class="text-4xl md:text-6xl font-extrabold text-white mb-6">Simple, Transparent Pricing</h1>
      <p class="text-base md:text-lg text-[var(--singr-text-secondary)] font-sans font-light leading-relaxed">
        Singr features a single, all-inclusive plan covering unlimited venues, rigs, and songbooks. Choose the payment frequency that works best for your entertainment business.
      </p>
      {errorMsg && (
        <div class="mt-4 p-2 inline-block rounded text-[10px] bg-yellow-500/10 border border-yellow-500/20 text-yellow-400 font-mono">
          ℹ️ Server offline (showing default billing options)
        </div>
      )}
    </div>

    <!-- Pricing Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
      {tiers.map((tier) => (
        <GlassCard className="p-10 flex flex-col justify-between relative overflow-hidden" hoverable={true}>
          {tier.interval === 'year' && (
            <div class="absolute top-0 right-0 bg-gradient-to-r from-[var(--singr-brand-start)] to-[var(--singr-brand-end)] text-white text-[10px] uppercase font-bold tracking-widest px-4 py-1.5 rounded-bl-lg">
              Best Value
            </div>
          )}
          <div>
            <h3 class="text-xl font-extrabold text-white mb-2">{tier.name}</h3>
            <div class="flex items-baseline gap-2 mb-6">
              <span class="text-5xl font-extrabold text-white font-sans">{formatPrice(tier.priceCents)}</span>
              <span class="text-sm text-[var(--singr-text-secondary)] font-sans">/{getIntervalText(tier.interval)}</span>
            </div>
            <div class="border-t border-[var(--singr-border)] my-6"></div>
            <ul class="list-none p-0 m-0 flex flex-col gap-4 mb-8">
              {commonFeatures.map((feat: string) => (
                <li class="flex items-center gap-3 text-sm text-[var(--singr-text-secondary)] font-sans">
                  <span class="text-[var(--singr-accent-primary)] font-bold text-base">✓</span>
                  {feat}
                </li>
              ))}
            </ul>
          </div>
          <a href={`${hostPortalUrl}/signup?plan=${getPlanName(tier.interval)}`} class="decoration-none w-full">
            <GlassButton variant={tier.interval === 'year' ? "primary" : "secondary"} className="w-full py-3 text-sm">
              Subscribe as Host
            </GlassButton>
          </a>
        </GlassCard>
      ))}
    </div>
  </section>
</Layout>
