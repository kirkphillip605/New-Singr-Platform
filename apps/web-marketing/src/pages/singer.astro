---
import Layout from '../layouts/Layout.astro';
import { GlassCard, GlassButton } from '@singr/ui';

const singerAppUrl = import.meta.env.PUBLIC_SINGER_APP_URL || "https://app.singrkaraoke.com";
---

<Layout title="For Singers — Singr Karaoke">
  <section class="py-12">
    <!-- Hero / Header -->
    <div class="max-w-3xl mx-auto text-center mb-16">
      <span class="text-xs font-bold uppercase tracking-widest text-[var(--singr-accent-secondary)] mb-3 block">Singers First Paradigm</span>
      <h1 class="text-4xl md:text-6xl font-extrabold text-white mb-6">Designed for Karaoke Vocalists</h1>
      <p class="text-base md:text-lg text-[var(--singr-text-secondary)] font-sans font-light leading-relaxed">
        The Singer ecosystem is designed to maximize engagement, streamline crowd rotation, and elevate the social aspect of a night out, providing a premium interactive experience directly from any smartphone.
      </p>
    </div>

    <!-- Section 1: Frictionless Usability & Show Discovery -->
    <div class="mb-20">
      <h2 class="text-2xl font-extrabold text-white mb-8 border-b border-[var(--singr-border)] pb-3 flex items-center gap-2">
        <span class="text-[var(--singr-accent-secondary)]">2.1</span> Frictionless Usability & Show Discovery
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <GlassCard className="p-6">
          <h3 class="text-lg font-bold text-white mb-3">Frictionless Access</h3>
          <p class="text-xs text-[var(--singr-text-secondary)] font-sans leading-relaxed m-0">
            Walk straight into a venue and interact with the platform immediately as a guest. There are no mandatory sign-up loops or gatekeeping mechanisms required to view the songbook or submit a song request.
          </p>
        </GlassCard>

        <GlassCard className="p-6">
          <h3 class="text-lg font-bold text-white mb-3">Intelligent Account Merging</h3>
          <p class="text-xs text-[var(--singr-text-secondary)] font-sans leading-relaxed m-0">
            When a guest singer is ready to register a profile, it takes just a few clicks. Past song requests, saved favorites, and request history get linked to the new account automatically so they never miss a beat.
          </p>
        </GlassCard>

        <GlassCard className="p-6">
          <h3 class="text-lg font-bold text-white mb-3">Discover Nearby Shows</h3>
          <p class="text-xs text-[var(--singr-text-secondary)] font-sans leading-relaxed m-0">
            Using location data, Singr displays nearby shows and events within close proximity, enabling instant access to venue information, directions, reviews, and interactive songbooks.
          </p>
        </GlassCard>
      </div>
    </div>

    <!-- Section 2: Live Show Interaction -->
    <div class="mb-20">
      <h2 class="text-2xl font-extrabold text-white mb-8 border-b border-[var(--singr-border)] pb-3 flex items-center gap-2">
        <span class="text-[var(--singr-accent-secondary)]">2.2</span> Live Show Interaction
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <GlassCard className="p-6">
          <h3 class="text-lg font-bold text-white mb-3">Private Show Gating</h3>
          <p class="text-xs text-[var(--singr-text-secondary)] font-sans leading-relaxed m-0">
            For wedding receptions, corporate parties, or pop-up private events, shows are hidden from the discovery map. Check in using a unique invite code generated by the host, or scan a QR code for automatic login.
          </p>
        </GlassCard>

        <GlassCard className="p-6">
          <h3 class="text-lg font-bold text-white mb-3">Check In & Geofencing</h3>
          <p class="text-xs text-[var(--singr-text-secondary)] font-sans leading-relaxed m-0">
            Choose a nearby show or enter an invite code to begin. Hosts may configure geographical restrictions, preventing distant users from checking in to ensure only actual venue attendees have access.
          </p>
        </GlassCard>

        <GlassCard className="p-6">
          <h3 class="text-lg font-bold text-white mb-3">Real-Time Rotation & Queue</h3>
          <p class="text-xs text-[var(--singr-text-secondary)] font-sans leading-relaxed m-0">
            Track the live singer queue and rotation directly from the app. Knowing your position reduces queue anxiety and lets you grab drinks safely without worrying about missing your turn.
          </p>
        </GlassCard>

        <GlassCard className="p-6">
          <h3 class="text-lg font-bold text-white mb-3">Show-Agnostic Favorites</h3>
          <p class="text-xs text-[var(--singr-text-secondary)] font-sans leading-relaxed m-0">
            Registered singers can build a favorite songs catalog of their go-to tracks. These favorites are show-agnostic, meaning you can submit requests directly from your favorites list at any Singr show.
          </p>
        </GlassCard>

        <GlassCard className="p-6">
          <h3 class="text-lg font-bold text-white mb-3">Virtual Round of Applause</h3>
          <p class="text-xs text-[var(--singr-text-secondary)] font-sans leading-relaxed m-0">
            Audience members can send "virtual applause" to singers currently performing on stage, fostering crowd engagement. Flaunt your accumulated virtual applauses on your singer profile.
          </p>
        </GlassCard>

        <GlassCard className="p-6">
          <h3 class="text-lg font-bold text-white mb-3">Host Tipping Jar</h3>
          <p class="text-xs text-[var(--singr-text-secondary)] font-sans leading-relaxed m-0">
            Show appreciation for your host by sending tips direct to their Cash App, Venmo, PayPal, or crypto. Singr does not facilitate payments, ensuring hosts keep 100% of their tips without extra platform fees.
          </p>
        </GlassCard>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="text-center">
      <GlassCard className="p-10 max-w-2xl mx-auto">
        <h2 class="text-3xl font-extrabold text-white mb-4">Start Singing Now</h2>
        <p class="text-sm text-[var(--singr-text-secondary)] font-sans mb-8 leading-relaxed">
          Join active shows instantly. Anonymous guest profiles are supported so you can join a show and request a song without completing any complex sign-ups.
        </p>
        <a href={singerAppUrl} class="decoration-none">
          <GlassButton variant="primary" className="px-8 py-3 text-sm">
            Launch Singer Web App
          </GlassButton>
        </a>
      </GlassCard>
    </div>
  </section>
</Layout>
