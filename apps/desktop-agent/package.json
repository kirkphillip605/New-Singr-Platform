{
  "name": "@singr/desktop-agent",
  "version": "0.0.1",
  "private": true,
  "description": "Electron desktop agent — replaces OpenKJ polling with WebSocket",
  "main": "dist/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.main.json && vite build",
    "lint": "echo 'No lint yet'",
    "type-check": "tsc -p tsconfig.renderer.json --noEmit && tsc -p tsconfig.main.json --noEmit",
    "clean": "rm -rf dist build"
  },
  "dependencies": {
    "@singr/shared": "workspace:*",
    "@singr/ui": "workspace:*",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@singr/config": "workspace:*",
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "typescript": "^5.8.0",
    "vite": "^6.1.1"
  }
}
