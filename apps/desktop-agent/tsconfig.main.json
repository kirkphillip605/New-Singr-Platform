{
  "extends": "../../packages/config/tsconfig.node.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": false,
    "declaration": false,
    "declarationMap": false,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/main.ts", "src/preload.ts", "src/lib/scanner.ts"],
  "exclude": ["src/renderer/**/*", "node_modules", "dist"]
}
