# =============================================
# Singr Platform — Environment Configuration
# =============================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Core Environment
NODE_ENV="development"
PORT=3001

POSTGRES_PASSWORD="Jameson5475"

# PostgreSQL Database
# For local dev: point to your host Postgres
DATABASE_URL="postgresql://kirkphillip:Jameson5475@db-postgres:5432/singr_dev?schema=public"
# For Docker: use the internal container hostname
# DATABASE_URL="postgresql://singr:YOUR_PASSWORD@db-postgres:95432/singr_db?schema=public"

# Redis Cache & Queues (BullMQ)
REDIS_URL="redis://localhost:6379"
# For Docker:
# REDIS_URL="redis://cache-redis:96379"

# Better Auth Configuration
BETTER_AUTH_SECRET="GENERATE_WITH_openssl_rand_-base64_32"
BETTER_AUTH_URL="http://localhost:3001"

# OAuth Providers
# Google/Apple social sign-in are registered ONLY when these values are set and
# are NOT the placeholders below. Leaving the placeholder values keeps the
# providers disabled so the API can start without valid OAuth credentials.
#
# Required OAuth redirect (callback) URIs to register with each provider:
#   Google:
#     Local: http://localhost:3001/api/auth/callback/google
#     Prod:  https://api.singrkaraoke.com/api/auth/callback/google
#   Apple:
#     Local: http://localhost:3001/api/auth/callback/apple
#     Prod:  https://api.singrkaraoke.com/api/auth/callback/apple
#   (Pattern is ${BETTER_AUTH_URL}/api/auth/callback/<provider>.)
#
# Apple note: APPLE_CLIENT_ID is the Services ID, and APPLE_CLIENT_SECRET must be
# a JWT client secret generated/signed from your Apple private key (.p8) + Key ID
# + Team ID. Apple only returns the user's name on the first consent.
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

APPLE_CLIENT_ID="your_apple_client_id"
APPLE_CLIENT_SECRET="your_apple_client_secret"

# Email & SMS Integrations
MAILJET_API_KEY="your_mailjet_key"
MAILJET_API_SECRET="your_mailjet_secret"

TWILIO_ACCOUNT_SID="your_twilio_sid"
TWILIO_AUTH_TOKEN="your_twilio_token"
TWILIO_VERIFY_SERVICE_SID="your_verify_sid"
TWILIO_PHONE_NUMBER="+16056004934"

# Disable SMS Auth Features (hides SMS OTP and 2FA components on auth pages)
NEXT_PUBLIC_DISABLE_SMS_AUTH="true"


# Stripe (Test Keys)
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRODUCT_ID="prod_TA8qHMDIDpGzoi"
STRIPE_MONTHLY_PRICE="price_1SDoYqEHv8jD9HNKhqkE6KYA"
STRIPE_SEMI_ANNUAL_PRICE="price_1SDoYrEHv8jD9HNKb4u0KBVx"
STRIPE_ANNUAL_PRICE="price_1SDoYrEHv8jD9HNKNPlSfrwB"


# Google Places API (or HERE)
GOOGLE_PLACES_API_KEY="AIzaSy..."
# Alternative:
# HERE_API_KEY="your_here_api_key"

# Sentry (Error Monitoring)
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# Domain & Subdomain Routing Configuration (Update for Production / local testing)
HOST_PORTAL_URL="http://localhost:3011"
NEXT_PUBLIC_HOST_PORTAL_URL="http://localhost:3011"
PUBLIC_HOST_PORTAL_URL="http://localhost:3011"

PUBLIC_SINGER_APP_URL="http://localhost:3012"
VITE_SINGER_APP_URL="http://localhost:3012"

PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3001"
VITE_API_URL="http://localhost:3001"
